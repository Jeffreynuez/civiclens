# CivicView backend — example env file.
# Copy to `.env` for local dev. In production (Render) these are set
# via the dashboard; do NOT commit a real .env to the repo.

# ─── External API keys ───────────────────────────────────────────────
# Congress.gov — required for live federal officials data. Free at:
#   https://api.congress.gov/sign-up/
CONGRESS_API_KEY=your_api_key_here

# Google Civic Information API — used by BallotTab for live polling-place
# + ballot data. App works without it (BallotTab shows the disabled
# state). Get a key at: https://console.cloud.google.com/apis/library
# GOOGLE_CIVIC_API_KEY=

# ─── Database ────────────────────────────────────────────────────────
# Local default is SQLite at backend/civiclens.db (zero-config).
# Production: paste the Render-provided Postgres URL. The legacy
# postgres:// scheme is auto-normalized to postgresql:// in db.py.
# DATABASE_URL=postgresql://user:pass@host:5432/civicview

# ─── Auth / sessions ─────────────────────────────────────────────────
# 32+ bytes of randomness. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Required in production. Local dev falls back to a hardcoded dev
# secret if unset, so you can boot without one.
# SESSION_SECRET=

# Cookie attributes:
#   COOKIE_SECURE=true     - required in production (HTTPS only).
#   COOKIE_SAMESITE=none   - required when frontend + backend live on
#                            different domains (Vercel + Render).
#                            Local dev (same-origin) keeps "lax".
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated. Local default covers localhost + 127.0.0.1 + the
# Tailscale IP for phone testing. Production: set to the Vercel URL(s).
# ALLOWED_ORIGINS=https://civicview.app,https://www.civicview.app
