# CivicView frontend — example env file.
# Copy to `.env.local` for local dev. In production (Vercel), set
# these in the project's Environment Variables UI; do NOT commit
# a real .env.local to the repo.

# Backend API URL.
#   Local dev:   http://localhost:8000
#   Production:  https://civicview-api.onrender.com (or wherever the
#                Render service ends up — check the Render dashboard).
# Must be reachable from the user's browser, so it has to be a public
# HTTPS URL in production.
NEXT_PUBLIC_API_URL=http://localhost:8000
